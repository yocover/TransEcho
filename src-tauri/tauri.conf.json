{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TransEcho",
  "version": "0.2.4",
  "identifier": "com.wangxin.transecho",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TransEcho - \u540c\u58f0\u4f20\u8bd1",
        "width": 480,
        "height": 640,
        "minWidth": 400,
        "minHeight": 650,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist",
      "signingIdentity": "Developer ID Application: INAGORA CO., LTD. (SZ26HJEMC7)"
    }
  }
}
